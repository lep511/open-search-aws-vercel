# Vercel OIDC Token (auto-injected in production; for local dev use `vercel env pull`)
VERCEL_OIDC_TOKEN=

# OpenSearch Serverless configuration (auto-populated from Vercel Marketplace integration)
OPEN_SEARCH_AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/Vercel/ROLE_NAME
OPEN_SEARCH_AWS_REGION=us-east-1
OPEN_SEARCH_OPENSEARCH_ENDPOINT=https://COLLECTION_ID.aoss.us-east-1.on.aws
OPEN_SEARCH_OPENSEARCH_COLLECTION_TYPE=SEARCH
